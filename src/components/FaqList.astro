---
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'faq'>[];
}

const { items } = Astro.props as Props;
---
<div class="grid">
  {items.map((item) => (
    <details class="card">
      <summary style="font-weight:700;cursor:pointer;">{item.data.question}</summary>
      <p>{item.data.answer}</p>
    </details>
  ))}
</div>
