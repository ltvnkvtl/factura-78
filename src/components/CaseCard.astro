---
interface Props {
  title: string;
  category: string;
  description: string;
  beforeAlt: string;
  afterAlt: string;
  image?: string;
}

const { title, category, description, beforeAlt, afterAlt, image } = Astro.props;
---

<div class="card case-card relative overflow-hidden">
  <div class="case-card__glare absolute inset-0 pointer-events-none z-10 opacity-0"></div>
  <div class="relative mb-4 rounded-lg overflow-hidden bg-[var(--color-bg-elevated)]">
    {image ? (
      <img src={image} alt={beforeAlt} class="w-full h-auto block" />
    ) : (
      <div class="aspect-[3/2] flex items-center justify-center text-[var(--color-text-tertiary)] text-sm">
        Фото «до» / «после»
      </div>
    )}
    <span class="absolute top-2 left-2 text-xs bg-[var(--color-bg-base)]/80 text-[var(--color-text-secondary)] px-2 py-0.5 rounded">До</span>
    <span class="absolute top-2 right-2 text-xs bg-[var(--color-accent-cta)]/95 text-[var(--color-on-accent)] px-2 py-0.5 rounded">После</span>
  </div>
  <span class="text-xs font-medium uppercase tracking-wider text-[var(--color-accent)] mb-1 block">{category}</span>
  <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1">{title}</h3>
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{description}</p>
</div>

<style>
  .case-card {
    will-change: transform;
    transform-origin: center center;
    box-shadow:
      0 4px 16px rgba(35, 26, 27, 0.07),
      0 1px 4px rgba(35, 26, 27, 0.05);
    transition:
      transform 0.65s cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 0.65s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .case-card__glare {
    transition: opacity 0.35s ease;
    border-radius: inherit;
  }
</style>

<script>
  function initCaseCardParallax() {
    document.querySelectorAll<HTMLElement>('.case-card').forEach((card) => {
      if (card.dataset.parallaxReady) return;
      card.dataset.parallaxReady = '1';

      const glare = card.querySelector<HTMLElement>('.case-card__glare');
      let raf: ReturnType<typeof requestAnimationFrame> | null = null;

      card.addEventListener('mousemove', (e: MouseEvent) => {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const r = card.getBoundingClientRect();
          const nx = (e.clientX - r.left) / r.width - 0.5;   // -0.5 … 0.5
          const ny = (e.clientY - r.top) / r.height - 0.5;   // -0.5 … 0.5

          const rx = ny * -7.5;   // rotateX: top/bottom tilt
          const ry = nx * 7.5;    // rotateY: left/right tilt

          card.style.transition = 'transform 0.08s linear, box-shadow 0.08s linear';
          card.style.transform =
            `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(14px)`;
          card.style.boxShadow = `
            ${-ry * 0.7}px ${rx * 0.7}px 32px rgba(101, 53, 57, 0.18),
            0 22px 50px rgba(35, 26, 27, 0.13)
          `;

          if (glare) {
            const gx = (nx + 0.5) * 100;
            const gy = (ny + 0.5) * 100;
            glare.style.background =
              `radial-gradient(ellipse at ${gx}% ${gy}%, rgba(255,255,255,0.22) 0%, transparent 62%)`;
            glare.style.opacity = '1';
          }
        });
      });

      card.addEventListener('mouseleave', () => {
        if (raf) cancelAnimationFrame(raf);
        card.style.transition =
          'transform 0.65s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.65s cubic-bezier(0.23, 1, 0.32, 1)';
        card.style.transform = '';
        card.style.boxShadow = '';
        if (glare) glare.style.opacity = '0';
      });
    });
  }

  initCaseCardParallax();
  document.addEventListener('astro:page-load', initCaseCardParallax);
</script>
