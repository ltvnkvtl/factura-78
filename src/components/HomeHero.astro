---
import business from '@data/business.json';
import { withBase } from '@/utils/basePath';
---

<section class="min-h-[92vh] flex items-end pb-16 bg-[var(--color-bg-base)] border-b border-[var(--color-border-subtle)] overflow-hidden relative" aria-labelledby="hero-heading">
  <div class="container w-full">
    <div class="grid grid-cols-12 gap-6 items-end">

      <!-- LEFT: Editorial text (cols 1-7) -->
      <div class="col-span-12 lg:col-span-7 pb-8 lg:pb-0">
        <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-8 font-semibold">
          Санкт-Петербург · Мастерская
        </p>
        <h1 id="hero-heading" class="mb-6 text-[var(--color-text-primary)]" style="font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 6rem); font-weight: 700; line-height: 0.95; letter-spacing: -0.025em;">
          Реставрация.<br>Не<br><em class="not-italic text-[var(--color-accent)]">замена.</em>
        </h1>
        <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] mb-10 max-w-md leading-relaxed font-subheading">
          Обувь, сумки и кожаные изделия — возвращаем им жизнь в Санкт-Петербурге
        </p>
        <div class="flex flex-wrap items-center gap-6">
          <a href={business.social.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Отправить фото
          </a>
          <a href={withBase('/kejsy/')} class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors no-underline flex items-center gap-2">
            Наши работы <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <!-- RIGHT: Stacked photos (cols 8-12) -->
      <div class="col-span-12 lg:col-span-5 relative hidden lg:block">
        <div class="relative h-[580px]">
          <!-- Back photo: B&W, offset up-right, solid shadow -->
          <div class="group absolute top-0 right-0 w-[72%] overflow-hidden" style="aspect-ratio: 3/4; box-shadow: 8px 8px 0 var(--color-border-default);">
            <img src={withBase('/images/before-after/bag.png')} alt="До реставрации" class="w-full h-full object-cover photo-bw" style="object-position: left center;" loading="eager" />
          </div>
          <!-- Front photo: B&W, offset down-left, border -->
          <div class="group absolute bottom-0 left-0 w-[76%] overflow-hidden" style="aspect-ratio: 3/4; border: 1px solid var(--color-border-default); box-shadow: 8px 8px 0 var(--color-neutral);">
            <img src={withBase('/images/before-after/shoes.png')} alt="После реставрации" class="w-full h-full object-cover photo-bw" style="object-position: right center;" loading="eager" />
          </div>
          <!-- Label -->
          <div class="absolute z-10 bg-[var(--color-accent)] text-white text-[11px] font-semibold uppercase tracking-[0.2em] px-3 py-1.5" style="bottom: 52%; right: 5%;">
            После
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
