---
interface Props {
  title: string;
  description?: string;
  beforeAlt: string;
  afterAlt: string;
}

const { title, description, beforeAlt, afterAlt } = Astro.props;
---

<section class="section bg-[var(--color-bg-surface)] border-y border-[var(--color-border-subtle)]" aria-labelledby="before-after-split-heading">
  <div class="container">
    <div class="max-w-3xl mb-8">
      <h2 id="before-after-split-heading" class="text-2xl md:text-3xl font-bold mb-2">{title}</h2>
      {description && <p class="text-[var(--color-text-secondary)] leading-relaxed">{description}</p>}
    </div>
    <div
      class="rounded-xl overflow-hidden border border-[var(--color-border-subtle)] bg-[var(--color-bg-elevated)] shadow-lg"
      role="img"
      aria-label={`${beforeAlt}. ${afterAlt}`}
    >
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="aspect-[4/3] md:aspect-auto md:min-h-[280px] relative border-b md:border-b-0 md:border-r border-[var(--color-border-subtle)]">
          <div class="absolute inset-0 flex items-center justify-center text-[var(--color-text-tertiary)] text-sm px-6 text-center">
            {beforeAlt}
          </div>
          <span class="absolute top-3 left-3 text-xs font-semibold bg-[var(--color-bg-base)]/90 text-[var(--color-text-secondary)] px-2.5 py-1 rounded-md border border-[var(--color-border-subtle)]">До</span>
        </div>
        <div class="aspect-[4/3] md:aspect-auto md:min-h-[280px] relative">
          <div class="absolute inset-0 flex items-center justify-center text-[var(--color-text-tertiary)] text-sm px-6 text-center">
            {afterAlt}
          </div>
          <span class="absolute top-3 left-3 text-xs font-semibold bg-[var(--color-accent-cta)] text-[var(--color-on-accent)] px-2.5 py-1 rounded-md">После</span>
        </div>
      </div>
    </div>
  </div>
</section>
