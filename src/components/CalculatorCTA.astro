---
import { withBase } from '@/utils/basePath';
interface Props { title?: string; subtitle?: string; }
const { title = 'Узнайте стоимость за 2 минуты', subtitle = 'Пройдите короткий опрос — калькулятор даст ориентировочную цену и срок без звонков' } = Astro.props;
---
<section class="section bg-[var(--color-bg-surface)] border-y border-[var(--color-border-subtle)]">
  <div class="container">
    <div class="max-w-3xl mx-auto rounded-2xl p-8 md:p-12 text-center" style="border: 1px solid rgba(200,150,74,0.3); background: linear-gradient(135deg, var(--color-bg-elevated) 0%, var(--color-bg-surface) 100%);">
      <p class="text-3xl mb-4" aria-hidden="true" style="color: #C8964A;">✦</p>
      <h2 class="text-2xl md:text-3xl font-semibold mb-3" style="font-family: var(--font-heading);">{title}</h2>
      <p class="mb-8 max-w-lg mx-auto" style="color: var(--color-text-secondary);">{subtitle}</p>
      <a href={withBase('/kalkulyator/')} class="btn-primary text-base">Перейти к калькулятору</a>
    </div>
  </div>
</section>
