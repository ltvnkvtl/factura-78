---
import business from '@data/business.json';

const { lat, lng } = business.geo;
const yandexEmbed =
  `https://yandex.ru/map-widget/v1/?ll=${lng}%2C${lat}&z=16&pt=${lng}%2C${lat}%2Cpm2rdm`;

function formatHours(): string {
  const parts: string[] = [];
  for (const row of business.openingHours) {
    const label =
      row.days === 'Mo-Fr' ? 'Пн–Пт'
      : row.days === 'Sa' ? 'Сб'
      : row.days === 'Su' ? 'Вс'
      : row.days;
    if (row.opens === 'closed') {
      parts.push(`${label}: выходной`);
      continue;
    }
    parts.push(`${label}: ${row.opens}–${row.closes}`);
  }
  return parts.join(' · ');
}

const hoursLine = formatHours();
---

<section
  aria-labelledby="map-heading"
  class="relative w-full overflow-hidden h-auto md:h-[460px]"
>
  <!-- Жёлтая карточка: static на мобильном, absolute overlay слева на десктопе -->
  <div
    class="relative z-10 w-full md:absolute md:top-0 md:left-0 md:w-[360px] md:h-full
           bg-[var(--color-accent)] p-8 md:p-10 flex flex-col justify-center"
  >
    <h2
      id="map-heading"
      class="font-extrabold uppercase leading-tight text-[var(--color-on-accent)]
             text-[2rem] md:text-[2.5rem] mb-6"
    >
      Приходите<br />к нам
    </h2>
    <ul class="space-y-2.5 text-[var(--color-on-accent)] text-base font-medium leading-snug">
      <li>{hoursLine}</li>
      <li>г. {business.address.city}, {business.address.street}</li>
      <li>
        <a
          href={`tel:${business.phone.replace(/[\s()\-]/g, '')}`}
          class="text-[var(--color-on-accent)] no-underline hover:underline"
        >
          тел. {business.phone}
        </a>
      </li>
    </ul>
  </div>

  <!-- Яндекс Карта: static 300px на мобильном, absolute inset-0 на десктопе -->
  <iframe
    title="Мастерская Фактура / 78 на карте"
    src={yandexEmbed}
    class="w-full h-[300px] md:absolute md:inset-0 md:h-full"
    style="border: 0; display: block;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
</section>
