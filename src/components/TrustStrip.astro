---
---
<section class="bg-[var(--color-bg-surface)] border-y border-[var(--color-border-subtle)] py-4">
  <div class="container">
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-extrabold text-[var(--color-accent-cta)]" style="font-family: var(--font-heading);">640★</span>
        <span class="text-xs text-[var(--color-text-tertiary)]">отзывов<br/>на Авито</span>
      </div>
      <div class="w-px h-8 bg-[var(--color-border-subtle)] hidden md:block" aria-hidden="true"></div>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-extrabold text-[var(--color-accent-cta)]" style="font-family: var(--font-heading);">5.0</span>
        <span class="text-xs text-[var(--color-text-tertiary)]">средний<br/>рейтинг</span>
      </div>
      <div class="w-px h-8 bg-[var(--color-border-subtle)] hidden md:block" aria-hidden="true"></div>
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-[var(--color-accent)]" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span class="text-xs text-[var(--color-text-tertiary)]">Доставка<br/>по СПб</span>
      </div>
      <div class="w-px h-8 bg-[var(--color-border-subtle)] hidden md:block" aria-hidden="true"></div>
      <div class="text-xs text-[var(--color-text-tertiary)]">Работаем<br/>с 2019 года</div>
    </div>
  </div>
</section>
