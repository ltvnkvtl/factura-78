---
interface Props {
  slug: string;
  title: string;
  shortDescription: string;
  priceFrom: number;
}

const { slug, title, shortDescription, priceFrom } = Astro.props;
---

<a href={`/uslugi/${slug}/`} class="card block no-underline cursor-pointer group">
  <h3 class="text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-200 mb-2">
    {title}
  </h3>
  <p class="text-sm text-[var(--color-text-secondary)] mb-4 leading-relaxed">
    {shortDescription}
  </p>
  <div class="flex items-center justify-between">
    <span class="text-sm font-medium text-[var(--color-accent)]">от {priceFrom.toLocaleString('ru-RU')} ₽</span>
    <span class="text-xs text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] transition-colors duration-200">Подробнее →</span>
  </div>
</a>
