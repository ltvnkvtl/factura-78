---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const bagWorks = Object.values(prices.bags.works);
---

<ServiceLayout
  title="Реставрация сумок"
  metaTitle="Реставрация, химчистка и восстановление сумок в СПб — Фактура / 78"
  metaDescription="Реставрация, химчистка и восстановление сумок в Санкт-Петербурге: чистка, покраска, обновление ручек, подкладки, швов и фурнитуры. Отправьте фото для оценки."
  h1="Реставрация, химчистка и восстановление сумок в Санкт-Петербурге"
  intro="Восстанавливаем сумки любых типов: кожаные, текстильные, рюкзаки и клатчи. Делаем химчистку, возвращаем цвет, форму и аккуратный внешний вид, а замену ручек, молний и фурнитуры выполняем как сопутствующие работы."
  works={[
    'Химчистка сумок и рюкзаков',
    'Реставрация кожи и текстиля',
    'Восстановление цвета и формы',
    'Ремонт и замена ручек',
    'Замена молнии',
    'Замена подкладки',
    'Покраска кожи',
    'Ремонт застёжек и фурнитуры',
    'Ремонт углов и дна',
    'Укрепление швов',
    'Восстановление формы',
  ]}
  prices={bagWorks}
  priceTableTitle="Реставрация сумок — цены"
  faq={[
    { question: 'Работаете ли вы с брендовых сумками?', answer: 'Да, принимаем брендовые и деликатные сумки на реставрацию. Сначала оцениваем состояние кожи, подкладки и фурнитуры, затем предлагаем восстановление и только при необходимости сопутствующий ремонт.' },
    { question: 'Можно ли перекрасить сумку в другой цвет?', answer: 'Да, выполняем перекраску и восстановление цвета кожаных сумок. Используем профессиональные краски, которые держатся долго и не пачкают одежду. Стоимость начинается от 2000 ₽.' },
    { question: 'Как долго занимает восстановление подкладки?', answer: 'Если нужна замена или восстановление подкладки, срок обычно составляет 5–10 рабочих дней в зависимости от конструкции. Материалы подбираем под стиль и назначение сумки.' },
  ]}
  cases={[
    {
      title: 'Реставрация кожаной сумки',
      category: 'Реставрация сумок',
      description: 'Восстановление цвета, формы и деталей кожаной сумки с заменой ручек и молнии',
      beforeAlt: 'Кожаная сумка с потёртостями и повреждёнными деталями — до реставрации',
      afterAlt: 'Кожаная сумка после полной реставрации',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/restavraciya-obuvi/', label: 'Реставрация обуви' },
    { href: '/uslugi/himchistka/', label: 'Химчистка сумок' },
    { href: '/uslugi/uhod-za-kozhej/', label: 'Уход за кожей' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
  ]}
  schemaService={{
    name: 'Реставрация, химчистка и восстановление сумок',
    description: 'Реставрация, химчистка и восстановление сумок в Санкт-Петербурге: чистка, покраска, обновление ручек, подкладки, швов и фурнитуры',
    lowPrice: 800,
    highPrice: 6000,
  }}
/>
