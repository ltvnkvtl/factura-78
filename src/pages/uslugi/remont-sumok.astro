---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const bagWorks = Object.values(prices.bags.works);
---

<ServiceLayout
  title="Ремонт сумок"
  metaTitle="Ремонт сумок в СПб — реставрация, покраска — Фактура / 78"
  metaDescription="Ремонт и реставрация сумок в Санкт-Петербурге: ручки, молнии, подкладка, покраска кожи. Отправьте фото для оценки."
  h1="Ремонт и реставрация сумок в Санкт-Петербурге"
  intro="Восстанавливаем сумки любых типов: кожаные, текстильные, рюкзаки, клатчи. Ремонтируем ручки, меняем молнии и подкладку, перекрашиваем кожу. Работаем аккуратно, сохраняя стиль и характер изделия."
  works={[
    'Ремонт и замена ручек',
    'Замена молнии',
    'Замена подкладки',
    'Покраска кожи',
    'Ремонт застёжек и фурнитуры',
    'Ремонт углов и дна',
    'Укрепление швов',
    'Восстановление формы',
  ]}
  prices={bagWorks}
  priceTableTitle="Ремонт сумок — цены"
  faq={[
    { question: 'Ремонтируете ли брендовые сумки?', answer: 'Да, работаем с сумками любых брендов. Подбираем фурнитуру и материалы максимально близко к оригиналу. Отправьте фото — оценим возможность ремонта.' },
    { question: 'Можно ли перекрасить сумку в другой цвет?', answer: 'Да, перекрашиваем кожаные сумки в любой цвет. Используем профессиональные краски, которые держатся долго и не пачкают одежду. Стоимость — от 2000 ₽.' },
    { question: 'Как долго занимает замена подкладки?', answer: 'Замена подкладки сумки занимает 5–10 рабочих дней в зависимости от сложности конструкции. Подкладочную ткань подбираем по вашему вкусу.' },
  ]}
  cases={[
    {
      title: 'Реставрация кожаной сумки',
      category: 'Ремонт сумок',
      description: 'Восстановление цвета, замена ручек и ремонт молнии на кожаной сумке',
      beforeAlt: 'Кожаная сумка с потёртостями и сломанной молнией — до ремонта',
      afterAlt: 'Кожаная сумка после полной реставрации',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/remont-obuvi/', label: 'Ремонт обуви' },
    { href: '/uslugi/uhod-za-kozhej/', label: 'Уход за кожей' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
  ]}
  schemaService={{
    name: 'Ремонт и реставрация сумок',
    description: 'Ремонт и реставрация сумок в Санкт-Петербурге: ручки, молнии, подкладка, покраска кожи',
    lowPrice: 800,
    highPrice: 6000,
  }}
/>
