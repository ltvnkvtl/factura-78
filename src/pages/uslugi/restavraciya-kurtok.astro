---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const jacketWorks = Object.values(prices.jackets.works);
---

<ServiceLayout
  title="Реставрация курток"
  metaTitle="Реставрация и восстановление кожаных курток в СПб — Фактура / 78"
  metaDescription="Реставрация и восстановление кожаных курток в Санкт-Петербурге: покраска, обновление подкладки, уход за кожей, замена молнии и фурнитуры. Оценка по фото."
  h1="Реставрация и восстановление кожаных курток в Санкт-Петербурге"
  intro="Восстанавливаем кожаные и замшевые куртки, возвращаем им цвет, форму и аккуратный внешний вид. Покраска, обновление подкладки, уход за кожей и локальный ремонт деталей выполняются в рамках комплексной реставрации."
  works={[
    'Реставрация кожаных и замшевых курток',
    'Покраска кожи и замши',
    'Восстановление цвета и формы',
    'Замена молнии (основная и карманы)',
    'Заплатки и устранение порезов',
    'Замена подкладки',
    'Ремонт швов и строчки',
    'Замена кнопок и фурнитуры',
    'Укорачивание рукавов',
    'Уход и защита кожи',
  ]}
  prices={jacketWorks}
  priceTableTitle="Реставрация курток — цены"
  faq={[
    { question: 'Можно ли восстановить порез на кожаной куртке?', answer: 'Да, устраняем порезы и повреждения в рамках реставрации. Подбираем кожу по цвету и фактуре, чтобы место восстановления выглядело максимально аккуратно.' },
    { question: 'Сколько стоит замена молнии на куртке?', answer: 'Замена основной молнии начинается от 2000 ₽. Чаще всего это сопутствующая работа при комплексном восстановлении куртки. Используем фурнитуру YKK и подбираем вариант под изделие.' },
    { question: 'Работаете ли вы с куртками из экокожи?', answer: 'Да, принимаем изделия из экокожи, но честно предупреждаем: возможности восстановления у неё ниже, чем у натуральной кожи. После оценки по фото предлагаем безопасный вариант работ.' },
    { question: 'Можно ли перекрасить куртку?', answer: 'Да, выполняем покраску и обновление кожаных и замшевых курток. Восстановление в исходный цвет начинается от 3000 ₽, смена цвета стоит дороже и обсуждается отдельно.' },
  ]}
  cases={[
    {
      title: 'Замена молнии на кожаной куртке',
      category: 'Реставрация курток',
      description: 'Восстановление куртки с заменой молнии YKK и обновлением посадки по изделию',
      beforeAlt: 'Кожаная куртка со сломанной молнией — до реставрации',
      afterAlt: 'Кожаная куртка после восстановления и замены молнии YKK',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/uhod-za-kozhej/', label: 'Покраска кожи' },
    { href: '/uslugi/restavraciya-obuvi/', label: 'Реставрация обуви' },
    { href: '/uslugi/restavraciya-sumok/', label: 'Реставрация сумок' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
  ]}
  schemaService={{
    name: 'Реставрация и восстановление кожаных курток',
    description: 'Реставрация и восстановление кожаных курток в Санкт-Петербурге: покраска, обновление подкладки, уход за кожей, замена молнии и фурнитуры',
    lowPrice: 1000,
    highPrice: 8000,
  }}
/>
