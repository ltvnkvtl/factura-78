---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const shoeWorks = Object.values(prices.shoes.works);
---

<ServiceLayout
  title="Реставрация обуви"
  metaTitle="Реставрация, химчистка и восстановление обуви в СПб — Фактура / 78"
  metaDescription="Реставрация, химчистка и восстановление обуви в Санкт-Петербурге: чистка, покраска, замена подошвы, обновление швов и фурнитуры. Оценка по фото, доставка по СПб."
  h1="Реставрация, химчистка и восстановление обуви в Санкт-Петербурге"
  intro="Возвращаем обуви чистоту, форму и аккуратный внешний вид. Работаем с кроссовками, ботинками, туфлями и сапогами: выполняем химчистку, покраску, восстановление формы и при необходимости сопутствующий ремонт."
  works={[
    'Химчистка обуви и кроссовок',
    'Реставрация кожи и замши',
    'Восстановление цвета и формы',
    'Замена подошвы',
    'Замена каблука и набоек',
    'Ремонт и замена молнии',
    'Покраска кожи и замши',
    'Прошив и укрепление швов',
    'Замена стелек',
    'Восстановление задников',
    'Растяжка обуви',
  ]}
  prices={shoeWorks}
  priceTableTitle="Реставрация обуви — цены"
  faq={[
    { question: 'Можно ли восстановить кроссовки с потёртой подошвой?', answer: 'Да, сначала оцениваем общее состояние пары, затем предлагаем оптимальное восстановление: химчистку, покраску, замену подошвы или локальный ремонт. Подбираем решение под конкретную модель.' },
    { question: 'Работаете ли вы с замшевой обувью?', answer: 'Да, замша и нубук — одно из наших основных направлений. Выполняем деликатную чистку, восстановление ворса, обновление цвета и при необходимости ремонт швов.' },
    { question: 'Сколько стоит восстановление набоек и каблуков?', answer: 'Замена набоек начинается от 300 ₽ за пару и обычно занимает 1 рабочий день. Подбираем материал по типу обуви и нагрузке.' },
    { question: 'Что делать, если обувь промокает?', answer: 'Чаще всего проблема связана с износом подошвы, швов или материала верха. Отправьте фото: предложим восстановление, герметизацию проблемных мест и защитную обработку.' },
  ]}
  cases={[
    {
      title: 'Замена подошвы на кроссовках Nike',
      category: 'Реставрация обуви',
      description: 'Восстановление пары с заменой изношенной подошвы и сохранением оригинального силуэта',
      beforeAlt: 'Кроссовки Nike с изношенной подошвой — до реставрации',
      afterAlt: 'Кроссовки Nike после восстановления и замены подошвы',
    },
    {
      title: 'Покраска замшевых ботинок',
      category: 'Реставрация обуви',
      description: 'Восстановление цвета и обработка защитным составом',
      beforeAlt: 'Замшевые ботинки с выцветшим цветом — до покраски',
      afterAlt: 'Замшевые ботинки после реставрации и покраски',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/himchistka/', label: 'Химчистка обуви' },
    { href: '/uslugi/uhod-za-kozhej/', label: 'Уход за кожей' },
    { href: '/uslugi/restavraciya-sumok/', label: 'Реставрация сумок' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
    { href: '/ceny/', label: 'Все цены' },
  ]}
  schemaService={{
    name: 'Реставрация, химчистка и восстановление обуви',
    description: 'Реставрация, химчистка и восстановление обуви в Санкт-Петербурге: чистка, покраска, замена подошвы, обновление швов и фурнитуры',
    lowPrice: 300,
    highPrice: 5000,
  }}
/>
