---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const jacketWorks = Object.values(prices.jackets.works);
---

<ServiceLayout
  title="Ремонт курток"
  metaTitle="Ремонт кожаных курток в СПб — Фактура / 78"
  metaDescription="Ремонт кожаных курток в Санкт-Петербурге: замена молнии, заплатки, покраска, подкладка. Оценка по фото."
  h1="Ремонт кожаных курток в Санкт-Петербурге"
  intro="Ремонтируем и реставрируем кожаные, замшевые куртки и изделия из экокожи. Заменяем молнии, ставим заплатки, перекрашиваем, обновляем подкладку. Продлеваем жизнь вашей любимой куртке."
  works={[
    'Замена молнии (основная и карманы)',
    'Заплатки и устранение порезов',
    'Покраска кожи и замши',
    'Замена подкладки',
    'Ремонт швов и строчки',
    'Замена кнопок и фурнитуры',
    'Укорачивание рукавов',
    'Восстановление формы',
  ]}
  prices={jacketWorks}
  priceTableTitle="Ремонт курток — цены"
  faq={[
    { question: 'Можно ли отремонтировать порез на кожаной куртке?', answer: 'Да, мы устраняем порезы с помощью профессиональных заплаток. Подбираем кожу по цвету и фактуре, чтобы заплатка была максимально незаметной.' },
    { question: 'Сколько стоит замена молнии на куртке?', answer: 'Замена основной молнии — от 2000 ₽. Используем фурнитуру YKK. Срок — 3–7 рабочих дней в зависимости от сложности.' },
    { question: 'Ремонтируете ли куртки из экокожи?', answer: 'Да, работаем с экокожей. Учтите, что возможности реставрации экокожи ограничены по сравнению с натуральной кожей, но базовый ремонт (молнии, швы, подкладка) выполняем.' },
    { question: 'Можно ли перекрасить куртку?', answer: 'Да, перекрашиваем кожаные и замшевые куртки. Покраска в оригинальный цвет — от 3000 ₽. Смена цвета — от 5000 ₽. Используем стойкие профессиональные краски.' },
  ]}
  cases={[
    {
      title: 'Замена молнии на кожаной куртке',
      category: 'Ремонт курток',
      description: 'Установка новой молнии YKK взамен сломанной, подбор по цвету',
      beforeAlt: 'Кожаная куртка со сломанной молнией — до ремонта',
      afterAlt: 'Кожаная куртка с новой молнией YKK после ремонта',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/uhod-za-kozhej/', label: 'Покраска кожи' },
    { href: '/uslugi/remont-obuvi/', label: 'Ремонт обуви' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
  ]}
  schemaService={{
    name: 'Ремонт кожаных курток',
    description: 'Ремонт кожаных курток в Санкт-Петербурге: замена молнии, заплатки, покраска, подкладка',
    lowPrice: 1000,
    highPrice: 8000,
  }}
/>
