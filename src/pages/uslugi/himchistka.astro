---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const cleaningWorks = Object.values(prices.cleaning.works);
---

<ServiceLayout
  title="Химчистка"
  metaTitle="Химчистка обуви и сумок в СПб — Фактура / 78"
  metaDescription="Химчистка обуви и сумок в Санкт-Петербурге: кожа, замша, текстиль. Удаление пятен, глубокая чистка, пропитка."
  h1="Химчистка обуви и сумок в Санкт-Петербурге"
  intro="Профессиональная чистка обуви и сумок из любых материалов. Удаляем пятна, солевые разводы, въевшуюся грязь. Возвращаем изделиям свежий вид, обрабатываем защитными составами."
  works={[
    'Стандартная чистка кожи',
    'Глубокая чистка замши и нубука',
    'Чистка текстильной обуви',
    'Удаление пятен и солевых разводов',
    'Чистка кожаных сумок',
    'Чистка текстильных сумок и рюкзаков',
    'Пропитка водоотталкивающим составом',
    'Дезодорирование',
  ]}
  prices={cleaningWorks}
  priceTableTitle="Химчистка — цены"
  faq={[
    { question: 'Можно ли почистить белые кроссовки?', answer: 'Да, чистим белые кроссовки из кожи, текстиля и комбинированных материалов. Возвращаем белизну, удаляем желтизну подошвы. Стоимость — от 1000 ₽.' },
    { question: 'Как удалить солевые разводы?', answer: 'Солевые разводы удаляем специализированными средствами. Результат зависит от материала и давности разводов. В большинстве случаев удаётся полностью убрать соль.' },
    { question: 'Что включает пропитка?', answer: 'Обрабатываем изделие водоотталкивающим составом после чистки. Это защищает от влаги и грязи на 2–3 месяца в зависимости от интенсивности использования.' },
    { question: 'Чистите ли замшевые сумки?', answer: 'Да, работаем с замшей. Используем специализированные средства, которые не повреждают ворс и восстанавливают фактуру материала.' },
  ]}
  cases={[
    {
      title: 'Химчистка белых кроссовок',
      category: 'Химчистка',
      description: 'Глубокая чистка и восстановление белизны кроссовок',
      beforeAlt: 'Грязные белые кроссовки — до химчистки',
      afterAlt: 'Чистые белые кроссовки после профессиональной химчистки',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/uhod-za-kozhej/', label: 'Уход за кожей' },
    { href: '/uslugi/restavraciya-obuvi/', label: 'Реставрация обуви' },
    { href: '/uslugi/restavraciya-sumok/', label: 'Реставрация сумок' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
  ]}
  schemaService={{
    name: 'Химчистка обуви и сумок',
    description: 'Химчистка обуви и сумок в Санкт-Петербурге: кожа, замша, текстиль. Удаление пятен, глубокая чистка.',
    lowPrice: 500,
    highPrice: 4000,
  }}
/>
