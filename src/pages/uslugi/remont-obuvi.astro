---
import ServiceLayout from '@layouts/ServiceLayout.astro';
import prices from '@data/prices.json';

const shoeWorks = Object.values(prices.shoes.works);
---

<ServiceLayout
  title="Ремонт обуви"
  metaTitle="Ремонт обуви в СПб — замена подошвы, каблуков — Фактура / 78"
  metaDescription="Профессиональный ремонт обуви в Санкт-Петербурге: замена подошвы, каблуков, молний, покраска. Оценка по фото, доставка по СПб."
  h1="Ремонт обуви в Санкт-Петербурге"
  intro="Возвращаем обуви рабочее состояние и внешний вид. Работаем с кроссовками, ботинками, туфлями, сапогами — любыми типами обуви. Используем качественные материалы и даём гарантию на все работы."
  works={[
    'Замена подошвы',
    'Замена каблука и набоек',
    'Ремонт и замена молнии',
    'Покраска кожи и замши',
    'Прошив и укрепление швов',
    'Замена стелек',
    'Ремонт задников',
    'Восстановление формы',
    'Растяжка обуви',
  ]}
  prices={shoeWorks}
  priceTableTitle="Ремонт обуви — цены"
  faq={[
    { question: 'Можно ли заменить подошву на кроссовках?', answer: 'Да, мы заменяем подошву на большинстве моделей кроссовок. Подбираем подошву по типу и назначению обуви. Стоимость — от 2500 ₽, срок — 3–7 рабочих дней.' },
    { question: 'Ремонтируете ли замшевую обувь?', answer: 'Да, работаем с замшей: чистка, покраска, восстановление ворса, ремонт швов. Замша требует особого подхода — используем специализированные средства.' },
    { question: 'Сколько стоит поставить набойки?', answer: 'Замена набоек — от 300 ₽ за пару. Время — обычно 1 рабочий день. Используем набойки разной жёсткости в зависимости от модели обуви.' },
    { question: 'Что делать, если обувь промокает?', answer: 'Причин может быть несколько: трещина в подошве, разошедшийся шов, износ материала. Отправьте фото — определим проблему и предложим решение.' },
  ]}
  cases={[
    {
      title: 'Замена подошвы на кроссовках Nike',
      category: 'Ремонт обуви',
      description: 'Полная замена изношенной подошвы с сохранением оригинального дизайна',
      beforeAlt: 'Кроссовки Nike с изношенной подошвой — до ремонта',
      afterAlt: 'Кроссовки Nike после замены подошвы',
    },
    {
      title: 'Покраска замшевых ботинок',
      category: 'Ремонт обуви',
      description: 'Восстановление цвета и обработка защитным составом',
      beforeAlt: 'Замшевые ботинки с выцветшим цветом — до покраски',
      afterAlt: 'Замшевые ботинки после покраски и обработки',
    },
  ]}
  relatedLinks={[
    { href: '/uslugi/himchistka/', label: 'Химчистка обуви' },
    { href: '/uslugi/uhod-za-kozhej/', label: 'Уход за кожей' },
    { href: '/dostavka/', label: 'Доставка по СПб' },
    { href: '/ceny/', label: 'Все цены' },
  ]}
  schemaService={{
    name: 'Ремонт обуви',
    description: 'Профессиональный ремонт обуви в Санкт-Петербурге: замена подошвы, каблуков, молний, покраска',
    lowPrice: 300,
    highPrice: 5000,
  }}
/>
