---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import FAQ from '@components/FAQ.astro';
import QuizCalculator from '@components/QuizCalculator';

const faq = [
  { question: 'Насколько точна онлайн-оценка?', answer: 'Калькулятор даёт ориентировочный диапазон стоимости. Точная цена определяется после осмотра изделия или оценки по фото. В большинстве случаев итоговая стоимость попадает в указанный диапазон.' },
  { question: 'Зачем отправлять фото?', answer: 'По фото мы определяем реальное состояние изделия, тип материала и объём работ. Это позволяет дать точную стоимость и срок реставрации, химчистки или сопутствующих работ до того, как вы привезёте вещь в мастерскую.' },
  { question: 'Можно ли рассчитать стоимость нескольких изделий?', answer: 'Калькулятор рассчитывает стоимость для одного изделия за раз. Для оценки нескольких вещей пройдите расчёт повторно или отправьте фото всех изделий в мессенджер — оценим всё сразу.' },
];
---

<BaseLayout
  title="Калькулятор стоимости реставрации и химчистки — Фактура / 78"
  description="Рассчитайте ориентировочную стоимость реставрации, химчистки и восстановления обуви, сумок и кожаных изделий онлайн. Бесплатная оценка по фото."
>
  <Breadcrumb items={[{ label: 'Калькулятор' }]} />

  <section class="section">
    <div class="container max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Рассчитайте стоимость реставрации онлайн</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mb-10">
        Ответьте на 4 вопроса и получите ориентировочную стоимость.
        Для точной оценки отправьте фото изделия.
      </p>

      <QuizCalculator client:visible />

      <div class="mt-16">
        <h2 class="text-xl font-semibold mb-6">Частые вопросы</h2>
        <FAQ items={faq} />
      </div>
    </div>
  </section>
</BaseLayout>
