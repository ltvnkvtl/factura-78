---
import BaseLayout from '@layouts/BaseLayout.astro';
import PromoStrip from '@components/PromoStrip.astro';
import HomeHero from '@components/HomeHero.astro';
import BeforeAfterSplit from '@components/BeforeAfterSplit.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CleaningSteps from '@components/CleaningSteps.astro';
import CaseCard from '@components/CaseCard.astro';
import BeforeAfterSlider from '@components/BeforeAfterSlider';
import FAQ from '@components/FAQ.astro';
import TrustBlock from '@components/TrustBlock.astro';
import MapSection from '@components/MapSection.astro';
import ContactCTA from '@components/ContactCTA.astro';
import services from '@data/services.json';
import { withBase } from '@/utils/basePath';

const faq = [
  { question: 'Как узнать стоимость ремонта?', answer: 'Отправьте фото изделия в WhatsApp или Telegram — мы оценим работу и сообщим ориентировочную стоимость в течение часа. Также можно воспользоваться онлайн-калькулятором на сайте.' },
  { question: 'Сколько времени занимает ремонт?', answer: 'Зависит от сложности: простые работы (замена набоек, стелек) — 1–2 дня. Комплексный ремонт (замена подошвы, покраска) — 3–7 рабочих дней. Сложная реставрация — до 14 дней.' },
  { question: 'Есть ли доставка?', answer: 'Да, работаем с доставкой по Санкт-Петербургу. Курьер заберёт изделие и привезёт обратно после ремонта. Подробности на странице «Доставка».' },
  { question: 'Какие материалы вы используете?', answer: 'Работаем с профессиональными материалами: краски Saphir, Tarrago, Angelus, клеи и подошвы от проверенных производителей. Подбираем материалы под конкретное изделие.' },
  { question: 'Даёте ли гарантию?', answer: 'Да, на все виды работ предоставляем гарантию. Срок зависит от типа ремонта: от 2 недель на мелкий ремонт до 6 месяцев на замену подошвы.' },
];

const orderSteps = [
  { num: '01', title: 'Отправьте фото', desc: 'Сфотографируйте пару и отправьте в WhatsApp или Telegram' },
  { num: '02', title: 'Получите оценку', desc: 'Определим объём работ и сообщим стоимость и сроки' },
  { num: '03', title: 'Сдайте пару', desc: 'Привезите в мастерскую или закажите доставку по СПб' },
  { num: '04', title: 'Заберите результат', desc: 'Заберите готовую обувь или получите курьером' },
];

const cleaningSteps = [
  { num: '01', title: 'Сухая подготовка', desc: 'Снимаем пыль и поверхностные загрязнения, разбираем шнурки и стельку при необходимости.' },
  { num: '02', title: 'Подошва и швы', desc: 'Аккуратно очищаем рант, протяжку и швы без повреждения клеевых швов.' },
  { num: '03', title: 'Химия под материал', desc: 'Подбираем средства и режим под кожу, замшу, нубук, текстиль или комбинированные панели.' },
  { num: '04', title: 'Пятна и въевшаяся грязь', desc: 'Точечно работаем со сложными загрязнениями, сохраняя цвет и фактуру.' },
  { num: '05', title: 'Форма и детали', desc: 'Восстанавливаем силуэт, подравниваем ворс замши, убираем заломы на текстиле.' },
  { num: '06', title: 'Финиш', desc: 'Пропитка или кондиционирование по типу материала, контроль результата перед выдачей.' },
];
---

<BaseLayout
  title="Ремонт и химчистка обуви в СПб — Фактура / 78"
  description="Ремонт и химчистка обуви в Санкт-Петербурге: кроссовки, кеды, ботинки. Сумки и кожа. Оценка по фото, доставка по СПб."
>
  <PromoStrip />

  <HomeHero />

  <BeforeAfterSplit
    title="Результат в одном кадре"
    description="Так удобнее сравнивать: одна и та же пара до и после обработки в мастерской."
    beforeAlt="Кроссовки с загрязнённым верхом и подошвой — до химчистки"
    afterAlt="Те же кроссовки после комплексной чистки и восстановления белого ранта"
  />

  <section class="section">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Услуги</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard
            slug={service.slug}
            title={service.title}
            shortDescription={service.shortDescription}
            priceFrom={service.priceFrom}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={withBase('/uslugi/')} class="btn-secondary">Все услуги</a>
      </div>
    </div>
  </section>

  <CleaningSteps steps={cleaningSteps} />

  <section class="section bg-[var(--color-bg-surface)] border-y border-[var(--color-border-subtle)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-10 text-center">Как сделать заказ</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {orderSteps.map((step) => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-[var(--color-accent-cta)] mb-3 font-[var(--font-heading)]">{step.num}</div>
            <h3 class="text-lg font-semibold mb-2">{step.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="cases-heading">
    <div class="container">
      <div class="flex items-center justify-between mb-8 gap-4">
        <h2 id="cases-heading" class="text-2xl md:text-3xl font-bold">Наши работы</h2>
        <a
          href={withBase('/kejsy/')}
          class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline transition-colors duration-200 shrink-0"
        >
          Все кейсы →
        </a>
      </div>

      <div class="max-w-3xl mx-auto mb-10">
        <BeforeAfterSlider
          client:visible
          title="Сравнение до и после"
          description="Ползунок на фото — типичный приём сникер-химчисток: наглядно видно объём работы."
          beforeAlt="Кроссовки с изношенной подошвой и потёртостями — до ремонта"
          afterAlt="Кроссовки после замены подошвы и комплексной чистки верха"
        />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <CaseCard
          title="Покраска кожаной сумки"
          category="Ремонт сумок"
          description="Восстановление цвета и покраска потёртой кожаной сумки в оригинальный тон"
          beforeAlt="Кожаная сумка с потёртостями — до покраски"
          afterAlt="Кожаная сумка после профессиональной покраски"
          image="/images/before-after/bag.png"
        />
        <CaseCard
          title="Замена молнии на куртке"
          category="Ремонт курток"
          description="Установка новой качественной молнии YKK на кожаную куртку"
          beforeAlt="Кожаная куртка со сломанной молнией — до ремонта"
          afterAlt="Кожаная куртка с новой молнией YKK"
          image="/images/before-after/jacket.png"
        />
        <CaseCard
          class="object-contain"
          title="Реставрация замшевой обуви"
          category="Ремонт обуви"
          description="Глубокая чистка и реставрация замшевых мокасин"
          beforeAlt="Замшевые мокасины до реставрации"
          afterAlt="Замшевые мокасины после реставрации"
          image="/images/before-after/shoes.png"
        />
      </div>
    </div>
  </section>

  <section class="section bg-[var(--color-bg-surface)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Отзывы наших клиентов</h2>
      <TrustBlock />
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Частые вопросы</h2>
      <FAQ items={faq} />
    </div>
  </section>

  <MapSection />

  <ContactCTA />
</BaseLayout>
