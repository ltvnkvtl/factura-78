---
import BaseLayout from '@layouts/BaseLayout.astro';
import PromoStrip from '@components/PromoStrip.astro';
import HomeHero from '@components/HomeHero.astro';
import NumbersStrip from '@components/NumbersStrip.astro';
import ServiceCard from '@components/ServiceCard.astro';
import ProcessTimeline from '@components/ProcessTimeline.astro';
import CalculatorCTA from '@components/CalculatorCTA.astro';
import ReviewsBlock from '@components/ReviewsBlock.astro';
import FAQ from '@components/FAQ.astro';
import MapSection from '@components/MapSection.astro';
import ContactCTA from '@components/ContactCTA.astro';
import services from '@data/services.json';
import { withBase } from '@/utils/basePath';

const faq = [
  { question: 'Как узнать стоимость реставрации или химчистки?', answer: 'Отправьте фото изделия в WhatsApp или Telegram — мы оценим объём работ и сообщим ориентировочную стоимость в течение часа. Также можно воспользоваться онлайн-калькулятором на сайте.' },
  { question: 'Сколько времени занимает восстановление изделия?', answer: 'Срок зависит от объёма работ: химчистка и базовый уход обычно занимают 1–3 дня, комплексная реставрация с покраской или заменой деталей — 3–7 рабочих дней. Сложное восстановление может занять до 14 дней.' },
  { question: 'Есть ли доставка?', answer: 'Да, работаем с доставкой по Санкт-Петербургу. Курьер заберёт изделие и привезёт его обратно после химчистки, реставрации или восстановления. Подробности на странице «Доставка».' },
  { question: 'Какие материалы вы используете?', answer: 'Работаем с профессиональными материалами: краски Saphir, Tarrago, Angelus, клеи и подошвы от проверенных производителей. Подбираем материалы под конкретное изделие.' },
  { question: 'Даёте ли гарантию?', answer: 'Да, на все виды работ предоставляем гарантию. Срок зависит от типа услуги: от 2 недель на локальные работы до 6 месяцев на замену подошвы и другие сложные восстановительные этапы.' },
];

const cleaningSteps = [
  { num: '01', title: 'Сухая подготовка', desc: 'Снимаем пыль и поверхностные загрязнения, разбираем шнурки и стельку при необходимости.' },
  { num: '02', title: 'Подошва и швы', desc: 'Аккуратно очищаем рант, протяжку и швы без повреждения клеевых швов.' },
  { num: '03', title: 'Химия под материал', desc: 'Подбираем средства и режим под кожу, замшу, нубук, текстиль или комбинированные панели.' },
  { num: '04', title: 'Пятна и въевшаяся грязь', desc: 'Точечно работаем со сложными загрязнениями, сохраняя цвет и фактуру.' },
  { num: '05', title: 'Форма и детали', desc: 'Восстанавливаем силуэт, подравниваем ворс замши, убираем заломы на текстиле.' },
  { num: '06', title: 'Финиш', desc: 'Пропитка или кондиционирование по типу материала, контроль результата перед выдачей.' },
];
---

<BaseLayout
  title="Реставрация и химчистка обуви, сумок и кожаных изделий в СПб — Фактура / 78"
  description="Реставрация, чистка, покраска и восстановление кроссовок, обуви, кожаных курток, кожаных и текстильных сумок в Санкт-Петербурге. Оценка по фото за час, доставка по СПб."
>
  <PromoStrip />
  <HomeHero />
  <NumbersStrip />

  <section class="section bg-[var(--color-bg-surface)] border-b border-[var(--color-border-subtle)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-semibold mb-8" style="font-family: var(--font-heading);">Услуги</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard slug={service.slug} title={service.title} shortDescription={service.shortDescription} priceFrom={service.priceFrom} />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={withBase('/uslugi/')} class="btn-secondary">Все услуги</a>
      </div>
    </div>
  </section>

  <ProcessTimeline steps={cleaningSteps} />
  <CalculatorCTA />

  <section class="section bg-[var(--color-bg-base)] border-b border-[var(--color-border-subtle)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-semibold mb-8 text-center" style="font-family: var(--font-heading);">Отзывы клиентов</h2>
      <ReviewsBlock />
    </div>
  </section>

  <section class="section bg-[var(--color-bg-base)]">
    <div class="container max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-semibold mb-8 text-center" style="font-family: var(--font-heading);">Частые вопросы</h2>
      <FAQ items={faq} />
    </div>
  </section>

  <MapSection />
  <ContactCTA />
</BaseLayout>
