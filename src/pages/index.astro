---
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CaseCard from '@components/CaseCard.astro';
import FAQ from '@components/FAQ.astro';
import TrustBlock from '@components/TrustBlock.astro';
import ContactCTA from '@components/ContactCTA.astro';
import business from '@data/business.json';
import services from '@data/services.json';

const faq = [
  { question: 'Как узнать стоимость ремонта?', answer: 'Отправьте фото изделия в WhatsApp или Telegram — мы оценим работу и сообщим ориентировочную стоимость в течение часа. Также можно воспользоваться онлайн-калькулятором на сайте.' },
  { question: 'Сколько времени занимает ремонт?', answer: 'Зависит от сложности: простые работы (замена набоек, стелек) — 1–2 дня. Комплексный ремонт (замена подошвы, покраска) — 3–7 рабочих дней. Сложная реставрация — до 14 дней.' },
  { question: 'Есть ли доставка?', answer: 'Да, работаем с доставкой по Санкт-Петербургу. Курьер заберёт изделие и привезёт обратно после ремонта. Подробности на странице «Доставка».' },
  { question: 'Какие материалы вы используете?', answer: 'Работаем с профессиональными материалами: краски Saphir, Tarrago, Angelus, клеи и подошвы от проверенных производителей. Подбираем материалы под конкретное изделие.' },
  { question: 'Даёте ли гарантию?', answer: 'Да, на все виды работ предоставляем гарантию. Срок зависит от типа ремонта: от 2 недель на мелкий ремонт до 6 месяцев на замену подошвы.' },
];

const steps = [
  { num: '01', title: 'Отправьте фото', desc: 'Сфотографируйте изделие и отправьте в WhatsApp или Telegram' },
  { num: '02', title: 'Получите оценку', desc: 'Мы определим объём работ и сообщим стоимость и сроки' },
  { num: '03', title: 'Привезите или закажите доставку', desc: 'Занесите изделие в мастерскую или вызовите курьера по СПб' },
  { num: '04', title: 'Заберите результат', desc: 'Заберите отремонтированное изделие или получите курьером' },
];
---

<BaseLayout
  title="Ремонт обуви, сумок и кожи в СПб — Фактура / 78"
  description="Профессиональный ремонт обуви, сумок и кожаных изделий в Санкт-Петербурге. Оценка по фото, доставка по СПб. Химчистка, покраска, реставрация."
>
  <!-- Hero -->
  <section class="section bg-[var(--color-bg-base)] relative overflow-hidden">
    <div class="container">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight mb-6">
          Ремонт обуви, сумок и кожаных изделий в&nbsp;<span class="text-[var(--color-accent)]">Санкт-Петербурге</span>
        </h1>
        <p class="text-lg text-[var(--color-text-secondary)] mb-8 leading-relaxed max-w-xl">
          Профессиональная реставрация, химчистка и покраска. Оценка по фото за час, доставка по СПб.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={business.social.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
            Отправить фото
          </a>
          <a href="/kalkulyator/" class="btn-secondary text-base">
            Рассчитать стоимость
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Наши услуги</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard
            slug={service.slug}
            title={service.title}
            shortDescription={service.shortDescription}
            priceFrom={service.priceFrom}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/uslugi/" class="btn-secondary">Все услуги</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section bg-[var(--color-bg-surface)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-10 text-center">Как мы работаем</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {steps.map(step => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-[var(--color-accent)] mb-3">{step.num}</div>
            <h3 class="text-lg font-semibold mb-2">{step.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cases preview -->
  <section class="section">
    <div class="container">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold">Наши работы</h2>
        <a href="/kejsy/" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline transition-colors duration-200">
          Все кейсы →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <CaseCard
          title="Реставрация подошвы кроссовок"
          category="Ремонт обуви"
          description="Полная замена изношенной подошвы с сохранением оригинального дизайна"
          beforeAlt="Кроссовки с изношенной подошвой — до ремонта"
          afterAlt="Кроссовки после замены подошвы"
        />
        <CaseCard
          title="Покраска кожаной сумки"
          category="Ремонт сумок"
          description="Восстановление цвета и покраска потёртой кожаной сумки в оригинальный тон"
          beforeAlt="Кожаная сумка с потёртостями — до покраски"
          afterAlt="Кожаная сумка после профессиональной покраски"
        />
        <CaseCard
          title="Замена молнии на куртке"
          category="Ремонт курток"
          description="Установка новой качественной молнии YKK на кожаную куртку"
          beforeAlt="Кожаная куртка со сломанной молнией — до ремонта"
          afterAlt="Кожаная куртка с новой молнией YKK"
        />
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section class="section bg-[var(--color-bg-surface)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Отзывы наших клиентов</h2>
      <TrustBlock />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Частые вопросы</h2>
      <FAQ items={faq} />
    </div>
  </section>

  <!-- CTA -->
  <ContactCTA />
</BaseLayout>
