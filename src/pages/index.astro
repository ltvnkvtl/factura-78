---
import BaseLayout from '@layouts/BaseLayout.astro';
import PromoStrip from '@components/PromoStrip.astro';
import HomeHero from '@components/HomeHero.astro';
import TickerStrip from '@components/TickerStrip.astro';
import TrustBlock from '@components/TrustBlock.astro';
import FAQ from '@components/FAQ.astro';
import MapSection from '@components/MapSection.astro';
import services from '@data/services.json';
import business from '@data/business.json';
import { withBase } from '@/utils/basePath';

const faq = [
  { question: 'Как узнать стоимость реставрации или химчистки?', answer: 'Отправьте фото изделия в WhatsApp или Telegram — мы оценим объём работ и сообщим ориентировочную стоимость в течение часа. Также можно воспользоваться онлайн-калькулятором на сайте.' },
  { question: 'Сколько времени занимает восстановление изделия?', answer: 'Срок зависит от объёма работ: химчистка и базовый уход обычно занимают 1–3 дня, комплексная реставрация с покраской или заменой деталей — 3–7 рабочих дней. Сложное восстановление может занять до 14 дней.' },
  { question: 'Есть ли доставка?', answer: 'Да, работаем с доставкой по Санкт-Петербургу. Курьер заберёт изделие и привезёт его обратно после работ.' },
  { question: 'Какие материалы вы используете?', answer: 'Работаем с профессиональными материалами: краски Saphir, Tarrago, Angelus, клеи и подошвы от проверенных производителей.' },
  { question: 'Даёте ли гарантию?', answer: 'Да, на все виды работ предоставляем гарантию. Срок — от 2 недель до 6 месяцев в зависимости от типа работ.' },
];

const cleaningSteps = [
  { num: '01', title: 'Сухая подготовка', desc: 'Снимаем пыль и поверхностные загрязнения, разбираем шнурки и стельку при необходимости.' },
  { num: '02', title: 'Подошва и швы', desc: 'Аккуратно очищаем рант, протяжку и швы без повреждения клеевых швов.' },
  { num: '03', title: 'Химия под материал', desc: 'Подбираем средства и режим под кожу, замшу, нубук, текстиль или комбинированные панели.' },
  { num: '04', title: 'Пятна и въевшаяся грязь', desc: 'Точечно работаем со сложными загрязнениями, сохраняя цвет и фактуру.' },
  { num: '05', title: 'Форма и детали', desc: 'Восстанавливаем силуэт, подравниваем ворс замши, убираем заломы на текстиле.' },
  { num: '06', title: 'Финиш', desc: 'Пропитка или кондиционирование по типу материала, контроль результата перед выдачей.' },
];
---

<BaseLayout
  title="Реставрация и химчистка обуви, сумок и кожаных изделий в СПб — Фактура / 78"
  description="Реставрация, чистка, покраска и восстановление кроссовок, обуви, кожаных курток, кожаных и текстильных сумок в Санкт-Петербурге. Оценка по фото за час, доставка по СПб."
>
  <PromoStrip />
  <HomeHero />
  <TickerStrip />

  <!-- Cases grid: editorial masonry -->
  <section class="section bg-[var(--color-bg-base)]" aria-labelledby="cases-heading">
    <div class="container">
      <div class="flex items-baseline justify-between mb-10 border-b border-[var(--color-border-subtle)] pb-4">
        <h2 id="cases-heading" class="text-2xl font-bold uppercase tracking-[0.1em]" style="font-family: var(--font-heading);">Наши работы</h2>
        <a href={withBase('/kejsy/')} class="text-xs uppercase tracking-[0.2em] font-semibold text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] no-underline transition-colors">Все кейсы →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group">
          <div class="overflow-hidden mb-4" style="aspect-ratio: 4/5;">
            <img src={withBase('/images/before-after/bag.png')} alt="Покраска кожаной сумки" class="w-full h-full object-cover photo-bw group-hover:scale-[1.03] transition-transform duration-500" style="object-position: right center;" loading="lazy" />
          </div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)] mb-1">Реставрация сумок</p>
          <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-heading);">Покраска кожаной сумки</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Восстановление цвета и покраска потёртой кожаной сумки</p>
        </div>
        <div class="group">
          <div class="overflow-hidden mb-4" style="aspect-ratio: 4/5;">
            <img src={withBase('/images/before-after/jacket.png')} alt="Замена молнии на куртке" class="w-full h-full object-cover photo-bw group-hover:scale-[1.03] transition-transform duration-500" style="object-position: left center;" loading="lazy" />
          </div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)] mb-1">Реставрация курток</p>
          <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-heading);">Замена молнии на куртке</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Кожаная куртка с установкой новой молнии YKK</p>
        </div>
        <div class="group">
          <div class="overflow-hidden mb-4" style="aspect-ratio: 4/5;">
            <img src={withBase('/images/before-after/shoes.png')} alt="Реставрация замшевой обуви" class="w-full h-full object-cover photo-bw group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
          </div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)] mb-1">Реставрация обуви</p>
          <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-heading);">Реставрация замшевой обуви</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Глубокая чистка и реставрация замшевых мокасин</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services: editorial list with dividers -->
  <section class="section bg-[var(--color-bg-surface)]" aria-labelledby="services-heading">
    <div class="container">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 lg:col-span-3">
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-2 font-semibold">Что мы делаем</p>
          <h2 id="services-heading" class="text-3xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-heading);">Услуги</h2>
        </div>
        <div class="col-span-12 lg:col-span-9">
          {services.map((service, i) => (
            <a href={withBase(`/uslugi/${service.slug}/`)} class="group flex items-baseline justify-between gap-4 py-5 border-t border-[var(--color-border-subtle)] no-underline hover:border-[var(--color-accent)] transition-colors duration-200">
              <span class="text-[11px] font-medium text-[var(--color-text-tertiary)] w-6 shrink-0">{String(i + 1).padStart(2, '0')}</span>
              <span class="flex-1 text-xl font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-200" style="font-family: var(--font-heading);">{service.title}</span>
              <span class="text-sm text-[var(--color-text-secondary)] hidden md:block">от {service.priceFrom.toLocaleString('ru-RU')} ₽</span>
              <span class="text-[var(--color-accent)] text-sm">→</span>
            </a>
          ))}
          <div class="border-t border-[var(--color-border-subtle)]"></div>
          <div class="mt-6">
            <a href={withBase('/uslugi/')} class="btn-secondary text-sm">Все услуги</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Numbers: large typographic stats -->
  <section class="bg-[var(--color-bg-base)] border-y border-[var(--color-border-subtle)] py-16">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-[var(--color-border-subtle)]">
        <div class="px-8 py-6 sm:py-0 text-center sm:text-left sm:first:pl-0">
          <p class="font-bold text-[var(--color-text-primary)] leading-none mb-2" style="font-family: var(--font-heading); font-size: clamp(4rem, 7vw, 6rem);">{business.reviews.avito.count}</p>
          <p class="text-sm font-subheading text-[var(--color-text-secondary)]">отзывов на Авито</p>
        </div>
        <div class="px-8 py-6 sm:py-0 text-center">
          <p class="font-bold text-[var(--color-accent)] leading-none mb-2" style="font-family: var(--font-heading); font-size: clamp(4rem, 7vw, 6rem);">5★</p>
          <p class="text-sm font-subheading text-[var(--color-text-secondary)]">средний рейтинг</p>
        </div>
        <div class="px-8 py-6 sm:py-0 text-center sm:text-right sm:last:pr-0">
          <p class="font-bold text-[var(--color-text-primary)] leading-none mb-2" style="font-family: var(--font-heading); font-size: clamp(4rem, 7vw, 6rem);">5</p>
          <p class="text-sm font-subheading text-[var(--color-text-secondary)]">лет в деле</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process: numbered typographic list -->
  <section class="section bg-[var(--color-bg-surface)]" aria-labelledby="process-heading">
    <div class="container">
      <div class="grid grid-cols-12 gap-8">
        <div class="col-span-12 lg:col-span-3">
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-2 font-semibold">Как проходит работа</p>
          <h2 id="process-heading" class="text-3xl font-bold" style="font-family: var(--font-heading);">Процесс</h2>
        </div>
        <div class="col-span-12 lg:col-span-9">
          {cleaningSteps.map((step) => (
            <div class="flex gap-8 py-6 border-t border-[var(--color-border-subtle)] items-start">
              <span class="font-bold text-4xl text-[var(--color-border-default)] leading-none shrink-0 w-12" style="font-family: var(--font-heading);">{step.num}</span>
              <div>
                <h3 class="font-bold text-lg mb-1 text-[var(--color-text-primary)]" style="font-family: var(--font-heading);">{step.title}</h3>
                <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
          <div class="border-t border-[var(--color-border-subtle)]"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews: pull-quote style -->
  <section class="section bg-[var(--color-bg-base)]" aria-labelledby="reviews-heading">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--color-border-subtle)]">
        {[
          { text: 'Сдала любимые лоферы — вернули как новые. Настоящие мастера своего дела.', author: 'Анна В.', source: 'Яндекс' },
          { text: 'Отличная работа по восстановлению кожаной сумки. Цвет совпал идеально. Рекомендую.', author: 'Михаил К.', source: '2ГИС' },
          { text: 'Уже третий раз обращаюсь. Молния на куртке, подошва на туфлях — всё на высшем уровне.', author: 'Светлана Р.', source: 'Авито' },
        ].map(review => (
          <div class="px-0 md:px-8 py-8 first:pl-0 last:pr-0">
            <p class="font-subheading text-xl leading-relaxed text-[var(--color-text-primary)] mb-4">«{review.text}»</p>
            <p class="text-xs uppercase tracking-[0.2em] font-semibold text-[var(--color-text-tertiary)]">— {review.author}, {review.source}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 pt-8 border-t border-[var(--color-border-subtle)]">
        <TrustBlock />
      </div>
    </div>
  </section>

  <!-- Contact: editorial address block -->
  <section class="section bg-[var(--color-bg-surface)] border-t border-[var(--color-border-subtle)]" aria-labelledby="contact-heading">
    <div class="container">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 lg:col-span-5">
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-3 font-semibold">Связаться</p>
          <h2 id="contact-heading" class="font-bold mb-8 text-[var(--color-text-primary)]" style="font-family: var(--font-heading); font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.95;">
            Оценим работу<br><em class="not-italic text-[var(--color-accent)]">по фото</em><br>за час
          </h2>
          <div class="flex flex-wrap gap-4">
            <a href={business.social.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp</a>
            <a href={business.social.telegram} target="_blank" rel="noopener noreferrer" class="btn-secondary">Telegram</a>
          </div>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-8">
          <div class="space-y-6">
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-1 font-semibold">Адрес</p>
              <p class="text-sm text-[var(--color-text-primary)] font-medium">{business.address.street}<br/>{business.address.city}</p>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-1 font-semibold">Телефон</p>
              <a href={`tel:+${business.phone.replace(/\D/g, '')}`} class="text-sm font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] no-underline transition-colors">{business.phone}</a>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-text-tertiary)] mb-1 font-semibold">Часы работы</p>
              <p class="text-sm text-[var(--color-text-secondary)]">Пн–Пт: 10:00–20:00<br/>Сб: 11:00–18:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-[var(--color-bg-base)]">
    <div class="container max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" style="font-family: var(--font-heading);">Частые вопросы</h2>
      <FAQ items={faq} />
    </div>
  </section>

  <MapSection />
</BaseLayout>
