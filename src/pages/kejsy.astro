---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import CaseCard from '@components/CaseCard.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { withBase } from '@/utils/basePath';

const cases = [
  { title: 'Покраска кожаной сумки', category: 'Реставрация сумок', description: 'Восстановление цвета и покраска потёртой кожаной сумки в оригинальный тон', beforeAlt: 'Кожаная сумка до покраски', afterAlt: 'Кожаная сумка после покраски', image: withBase('/images/before-after/bag.png') },
  { title: 'Замена молнии на куртке', category: 'Реставрация курток', description: 'Восстановление кожаной куртки с установкой новой молнии YKK, подобранной по цвету', beforeAlt: 'Кожаная куртка со сломанной молнией — до реставрации', afterAlt: 'Кожаная куртка после восстановления и замены молнии YKK', image: withBase('/images/before-after/jacket.png') },
  { title: 'Реставрация замшевой обуви', category: 'Реставрация обуви', description: 'Глубокая чистка, восстановление ворса и обновление цвета замшевых мокасин', beforeAlt: 'Замшевые мокасины до реставрации', afterAlt: 'Замшевые мокасины после реставрации', image: withBase('/images/before-after/shoes.png') },
  { title: 'Замена подошвы на кроссовках Nike', category: 'Реставрация обуви', description: 'Комплексное восстановление пары с заменой изношенной подошвы и чисткой верха', beforeAlt: 'Кроссовки Nike с изношенной подошвой — до восстановления', afterAlt: 'Кроссовки Nike после восстановления и замены подошвы' },
  { title: 'Химчистка белых кроссовок', category: 'Химчистка', description: 'Глубокая чистка и восстановление белизны кроссовок', beforeAlt: 'Грязные белые кроссовки — до химчистки', afterAlt: 'Чистые белые кроссовки после профессиональной химчистки' },
  { title: 'Покраска кожаных туфель', category: 'Уход за кожей', description: 'Восстановление цвета и нанесение защитного слоя', beforeAlt: 'Кожаные туфли с потёртостями — до покраски', afterAlt: 'Кожаные туфли после профессиональной покраски' },
];

const categories = ['Все', ...new Set(cases.map(c => c.category))];
---

<BaseLayout
  title="Наши работы — до и после — Фактура / 78"
  description="Примеры работ мастерской Фактура / 78: фото до и после реставрации, химчистки и восстановления обуви, сумок и курток. Реальные кейсы из Санкт-Петербурга."
>
  <Breadcrumb items={[{ label: 'Кейсы' }]} />

  <section class="section">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Наши работы — до и после</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mb-8 max-w-2xl">
        Реальные примеры химчистки, реставрации и восстановления. Каждый кейс — уникальная задача с индивидуальным решением.
      </p>

      <!-- Category filter (static, no JS needed for MVP) -->
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map((cat, i) => (
          <span class:list={[
            'px-4 py-2 rounded-full text-sm font-medium cursor-pointer transition-colors duration-200',
            i === 0
              ? 'bg-[var(--color-accent-cta)] text-[var(--color-on-accent)]'
              : 'bg-[var(--color-bg-surface)] text-[var(--color-text-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)]'
          ]}>
            {cat}
          </span>
        ))}
      </div>

      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 [&>*]:mb-6 [&>*]:break-inside-avoid">
        {cases.map(c => (
          <CaseCard {...c} />
        ))}
      </div>
    </div>
  </section>

  <ContactCTA title="Хотите такой же результат?" subtitle="Отправьте фото изделия — оценим работу бесплатно" />
</BaseLayout>
