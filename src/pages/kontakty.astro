---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import TrustBlock from '@components/TrustBlock.astro';
import business from '@data/business.json';
---

<BaseLayout
  title="Контакты мастерской Фактура / 78 — Санкт-Петербург"
  description="Контакты мастерской Фактура / 78: адрес, телефон, мессенджеры, часы работы. Санкт-Петербург."
>
  <Breadcrumb items={[{ label: 'Контакты' }]} />

  <section class="section">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-8">Контакты мастерской Фактура / 78</h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Contact info -->
        <div class="space-y-6">
          <div class="card">
            <h2 class="text-lg font-semibold mb-4">Как связаться</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <div class="text-sm text-[var(--color-text-tertiary)]">Телефон</div>
                  <a href={`tel:${business.phone.replace(/[\s()-]/g, '')}`} class="text-[var(--color-text-primary)] no-underline hover:text-[var(--color-accent)] transition-colors duration-200">
                    {business.phone}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <div class="text-sm text-[var(--color-text-tertiary)]">Адрес</div>
                  <div class="text-[var(--color-text-primary)]">{business.address.street}</div>
                  <div class="text-[var(--color-text-secondary)]">{business.address.city}</div>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <div class="text-sm text-[var(--color-text-tertiary)]">Часы работы</div>
                  <div class="text-[var(--color-text-primary)]">Пн–Пт: 10:00–20:00</div>
                  <div class="text-[var(--color-text-primary)]">Сб: 11:00–18:00</div>
                  <div class="text-[var(--color-text-secondary)]">Вс: выходной</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Messengers -->
          <div class="card">
            <h2 class="text-lg font-semibold mb-4">Написать нам</h2>
            <div class="flex flex-col gap-3">
              <a href={business.social.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary justify-center">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Написать в WhatsApp
              </a>
              <a href={business.social.telegram} target="_blank" rel="noopener noreferrer" class="btn-secondary justify-center">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                Написать в Telegram
              </a>
            </div>
          </div>

          <!-- Trust -->
          <TrustBlock />
        </div>

        <!-- Map -->
        <div class="card !p-0 overflow-hidden min-h-[400px]">
          <iframe
            src="https://yandex.ru/map-widget/v1/?ll=30.3351%2C59.9343&z=15&pt=30.3351%2C59.9343%2Cpm2rdm"
            width="100%"
            height="100%"
            style="min-height: 400px; border: 0;"
            loading="lazy"
            title="Мастерская Фактура / 78 на карте"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": business.name,
    "url": business.url,
    "telephone": business.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address.street,
      "addressLocality": business.address.city,
      "addressRegion": business.address.region,
      "postalCode": business.address.postalCode,
      "addressCountry": business.address.country
    },
    "hasMap": `https://yandex.ru/maps/?pt=${business.geo.lng},${business.geo.lat}&z=15`
  })} />
</BaseLayout>
