---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import FAQ from '@components/FAQ.astro';
import ContactCTA from '@components/ContactCTA.astro';
import business from '@data/business.json';

const address = `${business.address.street}, ${business.address.city}`;

const faq = [
  { question: 'Сколько стоит доставка?', answer: 'Стоимость доставки зависит от района: в пределах КАД — от 300 ₽ в одну сторону. Точную стоимость уточняйте при оформлении заказа.' },
  { question: 'Как быстро приедет курьер?', answer: 'Обычно в течение 1–2 дней с момента согласования. Точное время доставки обговариваем с вами.' },
  { question: 'Как упаковать изделие для курьера?', answer: 'Положите изделие в пакет или коробку, чтобы защитить от загрязнений при транспортировке. Для обуви подойдёт обувная коробка или плотный пакет.' },
  { question: 'Можно ли привезти изделие самостоятельно?', answer: `Конечно! Мастерская расположена по адресу: ${address}. Приносите в рабочее время без предварительной записи.` },
];
---

<BaseLayout
  title="Доставка по Санкт-Петербургу — Фактура / 78"
  description="Доставка обуви, сумок и кожаных изделий для ремонта по Санкт-Петербургу. Курьер заберёт и привезёт обратно."
>
  <Breadcrumb items={[{ label: 'Доставка' }]} />

  <section class="section">
    <div class="container max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-6">Доставка по Санкт-Петербургу</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mb-10 leading-relaxed">
        Не нужно ехать через весь город — курьер заберёт изделие и привезёт обратно после ремонта.
        Работаем по всему Санкт-Петербургу в пределах КАД.
      </p>

      <div class="space-y-8 mb-12">
        <div class="card">
          <h2 class="text-lg font-semibold mb-3">Как это работает</h2>
          <ol class="space-y-3 text-[var(--color-text-secondary)]">
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] font-bold shrink-0">1.</span>
              <span>Отправьте фото изделия и согласуйте ремонт</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] font-bold shrink-0">2.</span>
              <span>Договоритесь с курьером об удобном времени забора</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] font-bold shrink-0">3.</span>
              <span>Курьер заберёт изделие и доставит в мастерскую</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] font-bold shrink-0">4.</span>
              <span>После ремонта курьер привезёт изделие обратно</span>
            </li>
          </ol>
        </div>

        <div class="card">
          <h2 class="text-lg font-semibold mb-3">Стоимость и зоны</h2>
          <div class="space-y-2 text-[var(--color-text-secondary)]">
            <div class="flex justify-between">
              <span>В пределах КАД</span>
              <span class="text-[var(--color-accent)] font-medium">от 300 ₽</span>
            </div>
            <div class="flex justify-between">
              <span>За КАД (по согласованию)</span>
              <span class="text-[var(--color-accent)] font-medium">от 500 ₽</span>
            </div>
          </div>
          <p class="mt-3 text-sm text-[var(--color-text-tertiary)]">
            Цена указана за одну сторону. Доставка обратно — такая же стоимость.
          </p>
        </div>

        <div class="card">
          <h2 class="text-lg font-semibold mb-3">Самовывоз</h2>
          <p class="text-[var(--color-text-secondary)]">
            Вы всегда можете принести и забрать изделие самостоятельно.
            Мастерская расположена по адресу: <strong class="text-[var(--color-text-primary)]">{address}</strong>.
          </p>
          <p class="text-[var(--color-text-secondary)] mt-2">
            Пн–Пт: 10:00–20:00, Сб: 11:00–18:00
          </p>
        </div>
      </div>

      <h2 class="text-xl font-semibold mb-6">Частые вопросы о доставке</h2>
      <FAQ items={faq} />
    </div>
  </section>

  <ContactCTA title="Заказать доставку" subtitle="Напишите нам — согласуем удобное время" />
</BaseLayout>
